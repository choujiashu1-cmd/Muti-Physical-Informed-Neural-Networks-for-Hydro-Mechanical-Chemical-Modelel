# 3. 数据读取与出图对比
# ==========================================
# 使用 os.path 动态获取当前脚本所在目录，避免终端路径不一致导致找不到文件
current_dir = os.path.dirname(os.path.abspath(__file__))
profile_file = os.path.join(current_dir, 'MPINN_Profile_Data_1_10_20_50_RAR.csv')
settlement_file = os.path.join(current_dir, 'MPINN_Settlement_Data_RAR.csv')

try:
    df_pinn_prof = pd.read_csv(profile_file)
    df_pinn_sett = pd.read_csv(settlement_file)
    print(">>> 成功读取 PINN 数据！准备绘制对比图...")
except FileNotFoundError as e:
    print(f">>> 错误：未能找到 CSV 文件。报错详情：{e}")
    print(f"请确保 CSV 文件与本 Python 脚本位于同一文件夹: {current_dir}")
    raise

# 初始化解析解
solver = AnalyticalHMCSolution()
c0 = solver.params.c0

plot_times_years = [1, 10, 20, 50]
colors = ['purple', 'b', 'g', 'r']
line_styles = ['-', '--', '-.', ':']

# 生成解析解所用的网格 (可以更密一点保证光滑)
z_ana = np.linspace(0, solver.params.length, 200)
t_ana = np.logspace(-4, np.log10(100.0), 400)

plt.figure(figsize=(18, 6))

# --- 图 A：浓度剖面对比 ---
plt.subplot(1, 3, 1)
for i, t_yr in enumerate(plot_times_years):
    # 1. 绘制解析解 (实线)
    _, c_ana = solver.pore_pressure_and_concentration(z_ana, t_yr)
    plt.plot(z_ana, c_ana / c0, color=colors[i], linestyle='-', lw=2.5, label=f'Analytical: t={t_yr}y')
    
    # 2. 绘制 PINN 解 (虚线 + 散点)
    z_pinn = df_pinn_prof['Depth_m']
    c_pinn = df_pinn_prof[f'Concentration_kg_m3_{t_yr}yr'] / c0
    plt.plot(z_pinn, c_pinn, color=colors[i], linestyle='--', marker='o', markevery=10, markersize=5, lw=1.5, alpha=0.8, label=f'PINN: t={t_yr}y')

plt.title("Concentration Profiles\n(Solid: Analytical | Dashed: PINN)")
plt.xlabel("Depth (m)")
plt.ylabel("Normalized Concentration ($C/C_0$)")
plt.legend(fontsize=8, loc='upper right', ncol=2)
plt.grid(True, alpha=0.5)

# --- 图 B：孔压剖面对比 ---
plt.subplot(1, 3, 2)
for i, t_yr in enumerate(plot_times_years):
    # 1. 绘制解析解
    u_ana_pa, _ = solver.pore_pressure_and_concentration(z_ana, t_yr)
    plt.plot(z_ana, u_ana_pa / 1000.0, color=colors[i], linestyle='-', lw=2.5)
    
    # 2. 绘制 PINN 解
    u_pinn_kpa = df_pinn_prof[f'PorePressure_kPa_{t_yr}yr']
    plt.plot(z_pinn, u_pinn_kpa, color=colors[i], linestyle='--', marker='o', markevery=10, markersize=5, lw=1.5, alpha=0.8)

plt.title("Pore Pressure Profiles\n(Solid: Analytical | Dashed: PINN)")
plt.xlabel("Depth (m)")
plt.ylabel("Pore Pressure (kPa)")
plt.grid(True, alpha=0.5)

# --- 图 C：100 年沉降时程对比 ---
plt.subplot(1, 3, 3)
# 1. 绘制解析解 (黑色实线)
settlement_ana = [solver.surface_settlement_increment_mm(t) for t in t_ana]
plt.plot(t_ana, settlement_ana, 'k-', lw=3, label='Analytical (Corrected)')

# 2. 绘制 PINN 解 (红色散点)
t_pinn = df_pinn_sett['Time_years']
sett_pinn = df_pinn_sett['Settlement_mm']
plt.scatter(t_pinn, sett_pinn, color='red', s=10, alpha=0.6, label='PINN Prediction')

plt.title("Surface Settlement vs Time\n(Black Line: Analytical | Red Dots: PINN)")
plt.xlabel("Time (Years)")
plt.ylabel("Settlement (mm)")
plt.xscale('log')
plt.legend()
plt.grid(True, which="both", ls="--", alpha=0.5)

plt.tight_layout()
plt.show()
