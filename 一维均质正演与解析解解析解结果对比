#修改后的解析解与PINN对比
import numpy as np
import matplotlib.pyplot as plt
import pandas as pd
from dataclasses import dataclass
import os

# ==========================================
# 1. 物理参数与系数数据类 (保持绝对一致)
# ==========================================
@dataclass(frozen=True)
class HMCParameters:
    sec_per_year: float = 3.1536e7
    t_ref: float = 100.0 * 3.1536e7
    length: float = 1.0
    p0: float = 50000.0
    c0: float = 10.0
    n_series: int = 200

    mv: float = 5.0e-7
    mc: float = 1.05e-7 * 1000.0
    kd: float = 8.142e-7 * 1000.0
    kh: float = 1.0e-10

    r_gas: float = 8.314
    t_temp: float = 293.15
    m_solute: float = 0.0585
    gamma_w: float = 1.0e4
    omega: float = 0.02
    n0: float = 0.5
    rho_s: float = 2600.0
    tau: float = 0.25
    d0: float = 5e-10
    e_modulus: float = 1.49e6
    nu: float = 0.3

@dataclass(frozen=True)
class HMCCoefficients:
    beta1: float
    beta2: float
    q12: float
    q21: float
    q1: float
    q2: float

# ==========================================
# 2. 彻底修复的解析解求解器 (补回 p0，修正符号)
# ==========================================
class AnalyticalHMCSolution:
    def __init__(self, params: HMCParameters | None = None):
        self.params = params or HMCParameters()
        self.coeffs = self._build_coefficients()

    def _build_coefficients(self) -> HMCCoefficients:
        p = self.params
        kc = p.kh * (p.r_gas * p.t_temp / p.m_solute)
        beta1 = p.e_modulus * (1.0 - p.nu) / ((1.0 + p.nu) * (1.0 - 2.0 * p.nu))
        beta2 = beta1 * p.mc
        beta3 = p.kh / p.gamma_w
        beta4 = p.omega * kc / p.gamma_w
        beta5 = p.mv * p.c0 * (1.0 - p.rho_s * p.kd)
        beta6 = p.n0 + (1.0 - p.n0) * p.rho_s * p.kd + p.mc * p.c0 * (p.rho_s * p.kd - 1.0)
        beta7 = beta3 * (1.0 - p.omega) * p.c0
        beta8 = (1.0 - p.omega) * (beta4 * p.c0 - p.n0 * p.tau * p.d0)
        beta9 = (1.0 - p.n0) * p.rho_s * p.kd * p.c0

        denom = (
            (beta1 * p.mc - beta2 * p.n0) * (beta1 * beta5 + beta9)
            + (beta1 * beta6 + beta2 * beta9) * (beta1 * p.mv + p.n0)
        )

        a1 = beta1 * (beta7 * (beta1 * p.mc - beta2 * p.n0) + beta3 * (beta1 * beta6 + beta2 * beta9)) / denom
        a2 = -beta1 * (beta8 * (beta1 * p.mc - beta2 * p.n0) + beta4 * (beta1 * beta6 + beta2 * beta9)) / denom
        a3 = -beta1 * (beta3 * (beta1 * beta5 + beta9) - beta7 * (beta1 * p.mv + p.n0)) / denom
        a4 = beta1 * (beta4 * (beta1 * beta5 + beta9) - beta8 * (beta1 * p.mv + p.n0)) / denom

        disc = (a1 - a4) ** 2 + 4.0 * a2 * a3
        q1 = (a1 + a4 + np.sqrt(disc)) / 2.0
        q2 = (a1 + a4 - np.sqrt(disc)) / 2.0
        q21 = (q1 - a1) / a3
        q12 = (q2 - a4) / a2

        return HMCCoefficients(beta1, beta2, q12, q21, q1, q2)

    def pore_pressure_and_concentration(self, depth_m, time_years):
        p = self.params
        c = self.coeffs
        z = np.asarray(depth_m, dtype=np.float64).reshape(-1, 1)
        t_sec = float(time_years) * p.sec_per_year

        n = np.arange(p.n_series, dtype=np.float64).reshape(-1, 1)
        lam = (n + 0.5) * np.pi / p.length
        sin_term = np.sin(lam * z.T)
        coeff = 1.0 / (2.0 * n + 1.0)

        e1 = np.exp(-(lam**2) * c.q1 * t_sec)
        e2 = np.exp(-(lam**2) * c.q2 * t_sec)

        series_c = (c.q12 * p.p0 - p.c0) * e2 - c.q12 * (p.p0 - c.q21 * p.c0) * e1
        series_u = (p.p0 - c.q21 * p.c0) * e1 - c.q21 * (c.q12 * p.p0 - p.c0) * e2

        factor = 4.0 / ((1.0 - c.q12 * c.q21) * np.pi)
        concentration = factor * np.sum(coeff * sin_term * series_c, axis=0).reshape(-1, 1) + p.c0
        pore_pressure = factor * np.sum(coeff * sin_term * series_u, axis=0).reshape(-1, 1)
        return pore_pressure[:, 0], concentration[:, 0]

    def settlement(self, depth_m, time_years):
        p = self.params
        c = self.coeffs
        z = np.asarray(depth_m, dtype=np.float64).reshape(-1, 1)
        t_sec = float(time_years) * p.sec_per_year

        n = np.arange(p.n_series, dtype=np.float64).reshape(-1, 1)
        lam = (n + 0.5) * np.pi / p.length
        cos_term = np.cos(lam * z.T)
        coeff = 1.0 / ((2.0 * n + 1.0) * lam)

        e1 = np.exp(-(lam**2) * c.q1 * t_sec)
        e2 = np.exp(-(lam**2) * c.q2 * t_sec)

        # 修复后的瞬态级数项
        series = (
            -(c.beta2 + c.q21) * (p.c0 - c.q12 * p.p0) * e2
            + (1.0 + c.q12 * c.beta2) * (c.q21 * p.c0 - p.p0) * e1
        )

        factor = 4.0 / ((1.0 - c.q12 * c.q21) * c.beta1 * np.pi)
        wz_series = np.sum(coeff * cos_term * series, axis=0).reshape(-1, 1)
        
        # 修复后的稳态沉降项 (包含外部力学荷载 p0)
        wz_linear = (p.p0 + c.beta2 * p.c0) * (p.length - z) / c.beta1
        
        return (factor * wz_series + wz_linear)[:, 0]

    def surface_settlement_increment_mm(self, time_years):
        # 物理上起步严格为 0，不再需要强制相减，直接返回 t 时刻表面沉降即可
        wzt = self.settlement([0.0], time_years)[0]
        return wzt * 1000.0

